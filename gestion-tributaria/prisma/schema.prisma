generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model administrador {
  cuil             BigInt            @id(map: "cuil")
  id_estudio       Int?
  usuario          usuario           @relation(fields: [cuil], references: [CUIL_usuario], onDelete: NoAction, onUpdate: NoAction, map: "cuil_usuario")
  estudio_contable estudio_contable? @relation(fields: [id_estudio], references: [id_estudio], onDelete: NoAction, onUpdate: NoAction, map: "id_estudio")
  turno            turno[]
}

model cliente {
  cuil             BigInt            @id
  id_estudio       Int?
  usuario          usuario           @relation(fields: [cuil], references: [CUIL_usuario], onDelete: NoAction, onUpdate: NoAction, map: "cuil_usuario")
  estudio_contable estudio_contable? @relation(fields: [id_estudio], references: [id_estudio], onDelete: NoAction, onUpdate: NoAction, map: "id_estudio")
  inscripto_en     inscripto_en[]
  liquidacion      liquidacion[]
  turno            turno[]
}

model comprobante {
  numero_boleta  Int           @id @default(autoincrement())
  periodo_fiscal DateTime?     @db.Date
  importe        Float?        @db.Real
  liquidacion    liquidacion?
}

model entidad_tributaria {
  id_entidad   Int            @id @default(autoincrement())
  nombre       String?
  url          String?
  inscripto_en inscripto_en[]
}

model estudio_contable {
  id_estudio    Int             @id @default(autoincrement())
  administrador administrador[]
  cliente       cliente[]
}

model impuesto {
  id_impuesto Int           @id @default(autoincrement())
  formato     String?
  liquidacion liquidacion[]
}

model inscripto_en {
  clave              String?
  cuil_cliente       BigInt
  id_entidad         Int
  cliente            cliente            @relation(fields: [cuil_cliente], references: [cuil], onDelete: NoAction, onUpdate: NoAction, map: "cuil_cliente")
  entidad_tributaria entidad_tributaria @relation(fields: [id_entidad], references: [id_entidad], onDelete: NoAction, onUpdate: NoAction, map: "id_entidad")

  @@id([cuil_cliente, id_entidad])
}

model liquidacion {
  numero_boleta             Int          @id @default(autoincrement())
  periodo_fiscal            DateTime?    @db.Date
  importe                   Float?       @db.Real
  estado                    String?
  cuil_cliente              BigInt?
  id_impuesto               Int?
  numero_boleta_comprobante Int? @unique
  cliente                   cliente?     @relation(fields: [cuil_cliente], references: [cuil], onDelete: NoAction, onUpdate: NoAction, map: "cuil_cliente")
  impuesto                  impuesto?    @relation(fields: [id_impuesto], references: [id_impuesto], onDelete: NoAction, onUpdate: NoAction, map: "id_impuesto")
  comprobante               comprobante? @relation(fields: [numero_boleta_comprobante], references: [numero_boleta], onDelete: NoAction, onUpdate: NoAction, map: "numero_boleta")
}

model usuario {
  CUIL_usuario     BigInt         @id
  nombre_usuario   String?
  apellido_usuario String?
  email            String?        @unique
  telefono         String?
  administrador    administrador?
  cliente          cliente?
}

model clerk_user {
  id        String   @id
  email     String?
  firstName String?
  lastName  String?
  cuil      String?
  rol       String?
  createdAt DateTime @default(now())
}

model turno {
  fecha         DateTime      @db.Date
  hora          DateTime      @db.Time(0)
  cuil_admin    BigInt
  cuil_cliente  BigInt
  administrador administrador @relation(fields: [cuil_admin], references: [cuil], onDelete: NoAction, onUpdate: NoAction, map: "cuil_admin")
  cliente       cliente       @relation(fields: [cuil_cliente], references: [cuil], onDelete: NoAction, onUpdate: NoAction, map: "cuil_cliente")

  @@id([fecha, hora, cuil_admin, cuil_cliente], map: "pk_turno")
}
